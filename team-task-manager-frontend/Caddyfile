:80 {
	root * /app/dist
	encode gzip

	# Cache static assets (JS, CSS, images, fonts) aggressively
	@static {
		file
		path *.js *.css *.ico *.png *.jpg *.jpeg *.gif *.svg *.woff *.woff2 *.ttf *.eot
	}
	header @static Cache-Control "public, max-age=31536000, immutable"

	# No caching for HTML (ensures fresh index.html on deploy)
	@html {
		file
		path *.html
	}
	header @html Cache-Control "no-cache, no-store, must-revalidate"

	# SPA fallback: rewrite all non-file requests to index.html
	try_files {path} /index.html

	file_server
}
